# .env.example
# Copy this file to .env and fill in your actual values.
# NEVER commit .env — only commit .env.example as a template.
# See README.md for full onboarding guide.

# ──────────────────────────────────────────────────────────────────────────────
# ─ Application Configuration
# ──────────────────────────────────────────────────────────────────────────────
APP_NAME="Trading Analytics Platform"
DEBUG=False
DEFAULT_SYMBOL="^NSEI"
DEFAULT_PERIOD="3mo"
DEFAULT_INTERVAL="1d"

# ──────────────────────────────────────────────────────────────────────────────
# ─ Security
# ──────────────────────────────────────────────────────────────────────────────
SECRET_KEY="change-this-to-a-random-secure-key-in-production"

# ──────────────────────────────────────────────────────────────────────────────
# ─ Data Provider Selection
# ──────────────────────────────────────────────────────────────────────────────
# Available options:
#   - "deterministic": Mock data (for testing/demo)
#   - "yfinance":      Yahoo Finance (free, requires internet)
#   - "upstox":        Upstox broker API (requires credentials)
DATA_PROVIDER="yfinance"

# ──────────────────────────────────────────────────────────────────────────────
# ─ Upstox API Integration (required only if DATA_PROVIDER=upstox)
# ──────────────────────────────────────────────────────────────────────────────
# Get credentials from: https://developer.upstox.com/
UPSTOX_API_KEY="your-api-key-here"
UPSTOX_API_SECRET="your-api-secret-here"
UPSTOX_REDIRECT_URI="http://127.0.0.1:8000/auth/upstox/callback"
UPSTOX_ACCESS_TOKEN="your-access-token-here"

# ──────────────────────────────────────────────────────────────────────────────
# ─ Database Configuration (optional for future use)
# ──────────────────────────────────────────────────────────────────────────────
# Uncomment and configure if using a database backend:
# DATABASE_URL="sqlite:///./trading_analytics.db"
# DATABASE_URL="postgresql://user:password@localhost/trading_analytics"

# ──────────────────────────────────────────────────────────────────────────────
# ─ Redis Cache Configuration (optional for production caching)
# ──────────────────────────────────────────────────────────────────────────────
# Uncomment for production Redis cache (currently using in-memory cache):
# REDIS_URL="redis://localhost:6379/0"
# REDIS_PASSWORD="your-redis-password"

# ──────────────────────────────────────────────────────────────────────────────
# ─ News API Configuration (optional, RSS feeds work without this)
# ──────────────────────────────────────────────────────────────────────────────
# Get a free API key from: https://newsapi.org/
# RSS feeds will work without this, but NewsAPI provides more sources
NEWSAPI_KEY=""

# ──────────────────────────────────────────────────────────────────────────────
# ─ Logging Configuration (optional)
# ──────────────────────────────────────────────────────────────────────────────
LOG_LEVEL="INFO"
# LOG_FILE="logs/app.log"
