# .env.example — copy to .env and fill in your values

# App
APP_NAME="Trading Analytics Platform"
DEBUG=False
SECRET_KEY=change-this-to-a-random-secret-key

# Data provider: "yfinance" or "upstox"
DATA_PROVIDER=yfinance

# Database — leave empty if using Docker Compose (it auto-configures)
DATABASE_URL=postgresql://trading_user:trading_pass@localhost:5432/trading_db

# Redis
REDIS_URL=redis://localhost:6379

# Upstox (optional — get from developer.upstox.com)
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=http://127.0.0.1:8000/auth/upstox/callback
UPSTOX_ACCESS_TOKEN=

# News (optional — get from newsapi.org)
NEWSAPI_KEY=